{
  "$defs": {
    "DocumentMetadata": {
      "additionalProperties": false,
      "description": "Stable identity and revision for a policy document.",
      "properties": {
        "name": {
          "maxLength": 100,
          "minLength": 1,
          "pattern": "^[a-z][a-z0-9_-]*$",
          "title": "Name",
          "type": "string"
        },
        "version": {
          "maxLength": 100,
          "minLength": 1,
          "title": "Version",
          "type": "string"
        }
      },
      "required": [
        "name",
        "version"
      ],
      "title": "DocumentMetadata",
      "type": "object"
    },
    "PolicyRule": {
      "additionalProperties": false,
      "description": "Deterministic policy for one pinned playbook action.",
      "properties": {
        "action_name": {
          "title": "Action Name",
          "type": "string"
        },
        "approval_required": {
          "default": true,
          "title": "Approval Required",
          "type": "boolean"
        },
        "auto_approve_up_to": {
          "anyOf": [
            {
              "$ref": "#/$defs/RiskLevel"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "playbook_name": {
          "title": "Playbook Name",
          "type": "string"
        }
      },
      "required": [
        "playbook_name",
        "action_name"
      ],
      "title": "PolicyRule",
      "type": "object"
    },
    "RiskLevel": {
      "description": "Risk tier assigned to a proposed action.",
      "enum": [
        "low",
        "medium",
        "high"
      ],
      "title": "RiskLevel",
      "type": "string"
    }
  },
  "additionalProperties": false,
  "description": "Strict deterministic policy with an explicit default-deny posture.",
  "properties": {
    "apiVersion": {
      "const": "lumis.dev/v1",
      "title": "Apiversion",
      "type": "string"
    },
    "default_deny": {
      "default": true,
      "title": "Default Deny",
      "type": "boolean"
    },
    "kind": {
      "default": "RecoveryPolicy",
      "title": "Kind",
      "type": "string"
    },
    "metadata": {
      "$ref": "#/$defs/DocumentMetadata"
    },
    "rules": {
      "items": {
        "$ref": "#/$defs/PolicyRule"
      },
      "maxItems": 1000,
      "title": "Rules",
      "type": "array"
    }
  },
  "required": [
    "metadata"
  ],
  "title": "PolicyDocument",
  "type": "object"
}
