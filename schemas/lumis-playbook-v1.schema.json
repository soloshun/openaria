{
  "$defs": {
    "DocumentMetadata": {
      "additionalProperties": false,
      "description": "Stable identity and revision for a policy document.",
      "properties": {
        "name": {
          "maxLength": 100,
          "minLength": 1,
          "pattern": "^[a-z][a-z0-9_-]*$",
          "title": "Name",
          "type": "string"
        },
        "version": {
          "maxLength": 100,
          "minLength": 1,
          "title": "Version",
          "type": "string"
        }
      },
      "required": [
        "name",
        "version"
      ],
      "title": "DocumentMetadata",
      "type": "object"
    },
    "ParameterDefinition": {
      "additionalProperties": false,
      "description": "One typed and bounded action parameter.",
      "properties": {
        "allowed_values": {
          "items": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "integer"
              },
              {
                "type": "number"
              },
              {
                "type": "boolean"
              }
            ]
          },
          "maxItems": 100,
          "title": "Allowed Values",
          "type": "array"
        },
        "max_length": {
          "anyOf": [
            {
              "maximum": 10000,
              "minimum": 1,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Max Length"
        },
        "maximum": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Maximum"
        },
        "minimum": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Minimum"
        },
        "name": {
          "maxLength": 100,
          "minLength": 1,
          "pattern": "^[a-z][a-z0-9_]*$",
          "title": "Name",
          "type": "string"
        },
        "required": {
          "default": true,
          "title": "Required",
          "type": "boolean"
        },
        "type": {
          "$ref": "#/$defs/ParameterType"
        }
      },
      "required": [
        "name",
        "type"
      ],
      "title": "ParameterDefinition",
      "type": "object"
    },
    "ParameterType": {
      "description": "Primitive parameter types accepted by deterministic playbook actions.",
      "enum": [
        "string",
        "integer",
        "number",
        "boolean"
      ],
      "title": "ParameterType",
      "type": "string"
    },
    "PlaybookAction": {
      "additionalProperties": false,
      "description": "One allowlisted recommendation; it contains no executable implementation.",
      "properties": {
        "name": {
          "maxLength": 100,
          "minLength": 1,
          "pattern": "^[a-z][a-z0-9_-]*$",
          "title": "Name",
          "type": "string"
        },
        "parameters": {
          "items": {
            "$ref": "#/$defs/ParameterDefinition"
          },
          "maxItems": 50,
          "title": "Parameters",
          "type": "array"
        },
        "risk": {
          "$ref": "#/$defs/RiskLevel"
        },
        "summary": {
          "maxLength": 2000,
          "minLength": 1,
          "title": "Summary",
          "type": "string"
        }
      },
      "required": [
        "name",
        "summary",
        "risk"
      ],
      "title": "PlaybookAction",
      "type": "object"
    },
    "RiskLevel": {
      "description": "Risk tier assigned to a proposed action.",
      "enum": [
        "low",
        "medium",
        "high"
      ],
      "title": "RiskLevel",
      "type": "string"
    }
  },
  "additionalProperties": false,
  "description": "Strict versioned playbook made only of declarative action definitions.",
  "properties": {
    "actions": {
      "items": {
        "$ref": "#/$defs/PlaybookAction"
      },
      "maxItems": 100,
      "minItems": 1,
      "title": "Actions",
      "type": "array"
    },
    "apiVersion": {
      "const": "lumis.dev/v1",
      "title": "Apiversion",
      "type": "string"
    },
    "kind": {
      "default": "Playbook",
      "title": "Kind",
      "type": "string"
    },
    "metadata": {
      "$ref": "#/$defs/DocumentMetadata"
    }
  },
  "required": [
    "metadata",
    "actions"
  ],
  "title": "PlaybookDocument",
  "type": "object"
}
