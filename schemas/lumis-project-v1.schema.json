{
  "$defs": {
    "EvidenceProviderConfig": {
      "additionalProperties": false,
      "description": "One bounded local evidence provider composed by the reference CLI.",
      "properties": {
        "kinds": {
          "items": {
            "type": "string"
          },
          "title": "Kinds",
          "type": "array"
        },
        "maxItemCharacters": {
          "default": 8000,
          "maximum": 100000,
          "minimum": 1,
          "title": "Maxitemcharacters",
          "type": "integer"
        },
        "maxItems": {
          "default": 25,
          "maximum": 100,
          "minimum": 1,
          "title": "Maxitems",
          "type": "integer"
        },
        "maxTotalCharacters": {
          "default": 131072,
          "maximum": 1000000,
          "minimum": 1,
          "title": "Maxtotalcharacters",
          "type": "integer"
        },
        "path": {
          "title": "Path",
          "type": "string"
        },
        "provider": {
          "const": "local-json",
          "title": "Provider",
          "type": "string"
        },
        "redact": {
          "default": true,
          "title": "Redact",
          "type": "boolean"
        },
        "timeoutSeconds": {
          "default": 5.0,
          "exclusiveMinimum": 0,
          "maximum": 60,
          "title": "Timeoutseconds",
          "type": "number"
        }
      },
      "required": [
        "provider",
        "path"
      ],
      "title": "EvidenceProviderConfig",
      "type": "object"
    },
    "HttpJsonEvidenceProviderConfig": {
      "additionalProperties": false,
      "description": "Configuration for the independent generic HTTP JSON evidence connector.",
      "properties": {
        "allowedOrigins": {
          "items": {
            "type": "string"
          },
          "maxItems": 32,
          "minItems": 1,
          "title": "Allowedorigins",
          "type": "array"
        },
        "authHeader": {
          "default": "Authorization",
          "pattern": "^[!#$%&'*+\\-.^_`|~0-9A-Za-z]+$",
          "title": "Authheader",
          "type": "string"
        },
        "authScheme": {
          "default": "Bearer",
          "maxLength": 100,
          "minLength": 1,
          "pattern": "^[^\\r\\n]+$",
          "title": "Authscheme",
          "type": "string"
        },
        "kinds": {
          "items": {
            "type": "string"
          },
          "title": "Kinds",
          "type": "array"
        },
        "maxItemCharacters": {
          "default": 8000,
          "maximum": 100000,
          "minimum": 1,
          "title": "Maxitemcharacters",
          "type": "integer"
        },
        "maxItems": {
          "default": 25,
          "maximum": 100,
          "minimum": 1,
          "title": "Maxitems",
          "type": "integer"
        },
        "maxResponseBytes": {
          "default": 1048576,
          "maximum": 10485760,
          "minimum": 1,
          "title": "Maxresponsebytes",
          "type": "integer"
        },
        "maxTotalCharacters": {
          "default": 131072,
          "maximum": 1000000,
          "minimum": 1,
          "title": "Maxtotalcharacters",
          "type": "integer"
        },
        "provider": {
          "const": "http-json",
          "title": "Provider",
          "type": "string"
        },
        "redact": {
          "default": true,
          "title": "Redact",
          "type": "boolean"
        },
        "retries": {
          "default": 0,
          "maximum": 3,
          "minimum": 0,
          "title": "Retries",
          "type": "integer"
        },
        "timeoutSeconds": {
          "default": 5.0,
          "exclusiveMinimum": 0,
          "maximum": 60,
          "title": "Timeoutseconds",
          "type": "number"
        },
        "tokenEnv": {
          "anyOf": [
            {
              "pattern": "^[A-Za-z_][A-Za-z0-9_]*$",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Tokenenv"
        },
        "url": {
          "maxLength": 2048,
          "title": "Url",
          "type": "string"
        }
      },
      "required": [
        "provider",
        "url",
        "allowedOrigins"
      ],
      "title": "HttpJsonEvidenceProviderConfig",
      "type": "object"
    },
    "IncidentSourceConfig": {
      "additionalProperties": false,
      "description": "One configured local incident source for v1alpha1.",
      "properties": {
        "path": {
          "title": "Path",
          "type": "string"
        },
        "provider": {
          "const": "local-log",
          "title": "Provider",
          "type": "string"
        }
      },
      "required": [
        "provider",
        "path"
      ],
      "title": "IncidentSourceConfig",
      "type": "object"
    },
    "MemoryConfig": {
      "additionalProperties": false,
      "description": "A project-owned local memory location.",
      "properties": {
        "path": {
          "default": ".lumis/incidents.db",
          "title": "Path",
          "type": "string"
        },
        "provider": {
          "const": "sqlite",
          "default": "sqlite",
          "title": "Provider",
          "type": "string"
        }
      },
      "title": "MemoryConfig",
      "type": "object"
    },
    "ModelConfig": {
      "additionalProperties": false,
      "description": "Explicit model-assistance opt-in; disabled by default.",
      "properties": {
        "enabled": {
          "default": false,
          "title": "Enabled",
          "type": "boolean"
        }
      },
      "title": "ModelConfig",
      "type": "object"
    },
    "ObjectMetadata": {
      "additionalProperties": false,
      "description": "Portable object metadata shared by versioned configuration documents.",
      "properties": {
        "labels": {
          "additionalProperties": {
            "type": "string"
          },
          "title": "Labels",
          "type": "object"
        },
        "name": {
          "minLength": 1,
          "title": "Name",
          "type": "string"
        }
      },
      "required": [
        "name"
      ],
      "title": "ObjectMetadata",
      "type": "object"
    },
    "PostgresMemoryConfig": {
      "additionalProperties": false,
      "description": "Configuration for an optional independently packaged PostgreSQL store.",
      "properties": {
        "connectTimeoutSeconds": {
          "default": 10,
          "maximum": 60,
          "minimum": 1,
          "title": "Connecttimeoutseconds",
          "type": "integer"
        },
        "connectionUrlEnv": {
          "pattern": "^[A-Za-z_][A-Za-z0-9_]*$",
          "title": "Connectionurlenv",
          "type": "string"
        },
        "maxSearchCandidates": {
          "default": 1000,
          "maximum": 10000,
          "minimum": 1,
          "title": "Maxsearchcandidates",
          "type": "integer"
        },
        "provider": {
          "const": "postgres",
          "title": "Provider",
          "type": "string"
        },
        "schema": {
          "default": "lumis_memory",
          "pattern": "^[a-z_][a-z0-9_]{0,62}$",
          "title": "Schema",
          "type": "string"
        }
      },
      "required": [
        "provider",
        "connectionUrlEnv"
      ],
      "title": "PostgresMemoryConfig",
      "type": "object"
    },
    "ProjectSpec": {
      "additionalProperties": false,
      "description": "The stable v1 project specification.",
      "properties": {
        "environment": {
          "default": "local",
          "title": "Environment",
          "type": "string"
        },
        "evidenceProviders": {
          "items": {
            "anyOf": [
              {
                "$ref": "#/$defs/EvidenceProviderConfig"
              },
              {
                "$ref": "#/$defs/HttpJsonEvidenceProviderConfig"
              }
            ]
          },
          "title": "Evidenceproviders",
          "type": "array"
        },
        "incidentSources": {
          "items": {
            "$ref": "#/$defs/IncidentSourceConfig"
          },
          "title": "Incidentsources",
          "type": "array"
        },
        "memory": {
          "anyOf": [
            {
              "$ref": "#/$defs/MemoryConfig"
            },
            {
              "$ref": "#/$defs/PostgresMemoryConfig"
            }
          ],
          "title": "Memory"
        },
        "model": {
          "$ref": "#/$defs/ModelConfig"
        },
        "reports": {
          "$ref": "#/$defs/ReportsConfig"
        },
        "rules": {
          "$ref": "#/$defs/RulesConfig"
        }
      },
      "title": "ProjectSpec",
      "type": "object"
    },
    "ReportsConfig": {
      "additionalProperties": false,
      "description": "A project-owned report output location.",
      "properties": {
        "outputDir": {
          "default": ".lumis/reports",
          "title": "Outputdir",
          "type": "string"
        },
        "provider": {
          "default": "markdown",
          "enum": [
            "markdown",
            "json"
          ],
          "title": "Provider",
          "type": "string"
        }
      },
      "title": "ReportsConfig",
      "type": "object"
    },
    "RulesConfig": {
      "additionalProperties": false,
      "description": "Paths to versioned deterministic rule-set documents.",
      "properties": {
        "files": {
          "items": {
            "type": "string"
          },
          "title": "Files",
          "type": "array"
        }
      },
      "title": "RulesConfig",
      "type": "object"
    }
  },
  "additionalProperties": false,
  "description": "Versioned Lumis SDK project configuration document.\n\nThe loader accepts the deprecated v1alpha1 marker during the documented\ncompatibility window. New documents and generated schemas use v1.",
  "properties": {
    "apiVersion": {
      "const": "lumis.dev/v1",
      "title": "Apiversion",
      "type": "string"
    },
    "kind": {
      "const": "Project",
      "title": "Kind",
      "type": "string"
    },
    "metadata": {
      "$ref": "#/$defs/ObjectMetadata"
    },
    "spec": {
      "$ref": "#/$defs/ProjectSpec"
    }
  },
  "required": [
    "apiVersion",
    "kind",
    "metadata",
    "spec"
  ],
  "title": "ProjectDocument",
  "type": "object"
}
