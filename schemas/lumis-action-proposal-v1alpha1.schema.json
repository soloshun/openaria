{
  "$defs": {
    "EvidenceReference": {
      "additionalProperties": false,
      "description": "Stable evidence identity included in a proposal snapshot.",
      "properties": {
        "digest": {
          "maxLength": 64,
          "minLength": 64,
          "pattern": "^[0-9a-f]{64}$",
          "title": "Digest",
          "type": "string"
        },
        "id": {
          "maxLength": 200,
          "minLength": 1,
          "title": "Id",
          "type": "string"
        },
        "source": {
          "maxLength": 200,
          "minLength": 1,
          "title": "Source",
          "type": "string"
        }
      },
      "required": [
        "id",
        "source",
        "digest"
      ],
      "title": "EvidenceReference",
      "type": "object"
    },
    "ProposalState": {
      "description": "Persistable lifecycle state for an immutable proposal revision.",
      "enum": [
        "pending",
        "approved",
        "rejected",
        "expired",
        "superseded"
      ],
      "title": "ProposalState",
      "type": "string"
    },
    "RiskLevel": {
      "description": "Risk tier assigned to a proposed action.",
      "enum": [
        "low",
        "medium",
        "high"
      ],
      "title": "RiskLevel",
      "type": "string"
    }
  },
  "additionalProperties": false,
  "description": "Immutable, attributable recommendation with no execution authority.",
  "properties": {
    "action_name": {
      "title": "Action Name",
      "type": "string"
    },
    "approval_required": {
      "title": "Approval Required",
      "type": "boolean"
    },
    "created_at": {
      "format": "date-time",
      "title": "Created At",
      "type": "string"
    },
    "diagnosis_digest": {
      "maxLength": 64,
      "minLength": 64,
      "pattern": "^[0-9a-f]{64}$",
      "title": "Diagnosis Digest",
      "type": "string"
    },
    "diagnosis_id": {
      "maxLength": 200,
      "minLength": 1,
      "title": "Diagnosis Id",
      "type": "string"
    },
    "evidence": {
      "items": {
        "$ref": "#/$defs/EvidenceReference"
      },
      "maxItems": 100,
      "minItems": 1,
      "title": "Evidence",
      "type": "array"
    },
    "execution_allowed": {
      "default": false,
      "title": "Execution Allowed",
      "type": "boolean"
    },
    "expires_at": {
      "format": "date-time",
      "title": "Expires At",
      "type": "string"
    },
    "parameters": {
      "additionalProperties": {
        "anyOf": [
          {
            "type": "string"
          },
          {
            "type": "integer"
          },
          {
            "type": "number"
          },
          {
            "type": "boolean"
          }
        ]
      },
      "title": "Parameters",
      "type": "object"
    },
    "playbook_name": {
      "title": "Playbook Name",
      "type": "string"
    },
    "playbook_version": {
      "title": "Playbook Version",
      "type": "string"
    },
    "policy_name": {
      "title": "Policy Name",
      "type": "string"
    },
    "policy_version": {
      "title": "Policy Version",
      "type": "string"
    },
    "proposal_id": {
      "maxLength": 200,
      "minLength": 1,
      "title": "Proposal Id",
      "type": "string"
    },
    "revision": {
      "default": 1,
      "minimum": 1,
      "title": "Revision",
      "type": "integer"
    },
    "risk": {
      "$ref": "#/$defs/RiskLevel"
    },
    "state": {
      "$ref": "#/$defs/ProposalState"
    }
  },
  "required": [
    "proposal_id",
    "state",
    "diagnosis_id",
    "diagnosis_digest",
    "evidence",
    "playbook_name",
    "playbook_version",
    "action_name",
    "policy_name",
    "policy_version",
    "risk",
    "approval_required",
    "created_at",
    "expires_at"
  ],
  "title": "ActionProposal",
  "type": "object"
}
