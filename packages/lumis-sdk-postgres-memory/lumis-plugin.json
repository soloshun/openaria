{
  "apiVersion": "lumis.dev/v1",
  "kind": "PluginManifest",
  "metadata": {
    "name": "postgres-memory",
    "version": "0.1.1"
  },
  "spec": {
    "entryPoint": "postgres-memory",
    "capabilities": [
      "memory_store"
    ],
    "supportStatus": "official",
    "sdk": {
      "minimum": "0.0.8",
      "maximumExclusive": "2.0.0"
    },
    "requiredAuthorities": [
